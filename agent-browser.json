{
  "plugins": [
    {
      "args": [
        "-y",
        "agent-browser-plugin-captcha"
      ],
      "capabilities": [
        "command.run",
        "captcha.solve"
      ],
      "command": "npx",
      "name": "captcha",
      "source": "npm:agent-browser-plugin-captcha"
    },
    {
      "args": [
        "-y",
        "@company/agent-browser-plugin-vault"
      ],
      "capabilities": [
        "credential.read"
      ],
      "command": "npx",
      "name": "vault",
      "source": "npm:@company/agent-browser-plugin-vault"
    },
    {
      "args": [
        "-y",
        "github:org/agent-browser-plugin-cloud-browser"
      ],
      "capabilities": [
        "browser.provider"
      ],
      "command": "npx",
      "name": "cloud-browser",
      "source": "github:org/agent-browser-plugin-cloud-browser"
    },
    {
      "name": "stealth",
      "command": "node",
      "args": ["./plugins/agent-browser-plugin-stealth/dist/index.js"],
      "capabilities": ["launch.mutate"]
    },
    {
      "name": "agent-browser-plugin-userprofile-browser",
      "command": "node",
      "args": ["./plugins/agent-browser-plugin-userprofile-browser/dist/index.js"],
      "capabilities": ["browser.provider"]
    }
  ]
}
